# Secrets — never commit
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Expo / Metro
.expo/
dist/
web-build/
# NB : backend/web/ (export web servi par le backend) EST versionné — `railway up`
# respecte .gitignore, donc l'ignorer le retire du déploiement. Re-générer avant
# de committer : expo export -p web --output-dir backend/web

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Base de données + sauvegardes (données utilisateur — jamais dans git)
backend/db/*.db
backend/db/*.db-journal
backend/db/*.json

# Artefacts générés
scripts/.botEngine.bundle.mjs
.railway-login*.txt

# Misc
npm-debug.*
*.log
.DS_Store

# Ancien clone GitHub vide (pas l'app)
OCHE/
