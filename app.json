{
  "expo": {
    "name": "HOCHE",
    "slug": "hoche-app",
    "version": "1.1.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hoche.app"
    },
    "android": {
      "package": "com.hoche.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A0F08"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#1A0F08"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "HOCHE utilise ta position pour te classer dans ta région et en Europe."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C8472F"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "HOCHE accède à tes photos pour choisir un avatar."
        }
      ]
    ],
    "scheme": "hoche",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea933746-8d2b-459d-b5b2-4a05d448a4e0"
      }
    },
    "owner": "panda_png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ea933746-8d2b-459d-b5b2-4a05d448a4e0"
    }
  }
}
